# Notebook — local environment.
# Copy this file to `.env` (gitignored) and fill in your Supabase project values.
# The app runs fully offline/local-first WITHOUT these; they only enable sync + the
# two Edge Functions (translate-phrase, synthesise-phrase).
#
# Find these in the Supabase dashboard → Project Settings → API.

SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_ANON_KEY=YOUR-PUBLIC-ANON-KEY

# NOTE: never put ANTHROPIC_API_KEY or GOOGLE_TTS_SERVICE_ACCOUNT here — those live
# ONLY in the Supabase Edge Function environment (set via the dashboard / CLI secrets).
